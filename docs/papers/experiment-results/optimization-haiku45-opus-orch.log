```python
import apis

# First, get the supervisor's account passwords
passwords = apis.supervisor.show_account_passwords()
print("Passwords retrieved")

# Find Spotify password
spotify_password = None
for account in passwords:
    if account.get('app') == 'Spotify':
        spotify_password = account.get('password')
        break

print(f"Spotify password found: {spotify_password is not None}")

# Login to Spotify
apis.spotify.login(email="joyce-weav@gmail.com", password=spotify_password)
print("Logged in to Spotify")

# Get user's playlists
playlists = apis.spotify.get_playlists()
print(f"Found {len(playlists)} playlists")

# Track the most-liked song across all playlists
most_liked_song = None
max_likes = -1

# Iterate through each playlist
for playlist in playlists:
    playlist_id = playlist['id']
    print(f"Checking playlist: {playlist['name']}")
    
    # Get tracks in this playlist
    tracks = apis.spotify.get_playlist_tracks(playlist_id=playlist_id)
    print(f"  Found {len(tracks)} tracks")
    
    # Check each track's likes
    for track in tracks:
        track_id = track['id']
        track_name = track['name']
        
        # Get track details including likes
        track_details = apis.spotify.get_track(track_id=track_id)
        likes = track_details.get('popularity', 0)
        
        print(f"    {track_name}: {likes} likes")
        
        if likes > max_likes:
            max_likes = likes
            most_liked_song = track_name

print(f"\nMost-liked song: {most_liked_song} with {max_likes} likes")

# Complete the task with the answer
apis.supervisor.complete_task(answer=most_liked_song)
