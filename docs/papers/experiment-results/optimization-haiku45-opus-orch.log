        pid = p.get('id') or p.get('playlist_id')
        if pid:
            playlist_ids.append(pid)

print(f"Playlist IDs: {playlist_ids}")

# Collect all songs from all playlists with their like counts
all_songs = {}

for playlist_id in playlist_ids:
    page = 1
    max_pages = 5  # Limit pages to avoid infinite loops
    while page <= max_pages:
        playlist_details = apis.spotify.show_playlist(access_token=token, playlist_id=playlist_id, page=page)
        print(f"Playlist {playlist_id} page {page}: {playlist_details}")
        
        if isinstance(playlist_details, dict):
            songs = playlist_details.get('songs', [])
        else:
            songs = playlist_details
        
        if not songs:
            break
        
        for song in songs:
            song_id = song.get('id') or song.get('song_id')
            song_title = song.get('title') or song.get('name')
            
            # Use likes from the song object directly if available
            likes = song.get('likes', 0)
            
            # Store song with highest like count
            if song_id not in all_songs or likes > all_songs[song_id]['likes']:
                all_songs[song_id] = {
                    'title': song_title,
                    'likes': likes
                }
        
        page += 1

print(f"All songs collected: {all_songs}")

# Find the song with the most likes
if all_songs:
    most_liked_song = max(all_songs.items(), key=lambda x: x[1]['likes'])
    most_liked_title = most_liked_song[1]['title']
    most_liked_count = most_liked_song[1]['likes']
    print(f"Most-liked song: {most_liked_title} with {most_liked_count} likes")
    
    apis.supervisor.complete_task(answer=most_liked_title)
else:
