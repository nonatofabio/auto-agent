"""
AppWorld agent — the file auto-agent will modify to improve performance.

This is a minimal ReAct-style agent that uses an LLM to generate code
for AppWorld tasks. Auto-agent can modify the system prompt, add tools,
change the loop logic, etc.
"""

import os
import json
import subprocess
import sys
from appworld import AppWorld

MAX_STEPS = int(os.environ.get("MAX_STEPS", "10"))
PYTHON = sys.executable
LLM_SCRIPT = os.path.join(os.path.dirname(__file__), "llm_call.py")

# --- System Prompt ---
SYSTEM_PROMPT = """You are an autonomous agent that completes tasks by writing Python code.
You interact with AppWorld apps (Spotify, Amazon, Venmo, etc.) via API calls.

API call format: apis.{app_name}.{api_name}(**parameters)

## Workflow
1. First, get passwords: apis.supervisor.show_account_passwords()
2. Search for relevant APIs: apis.api_docs.search_api_docs(query="keyword")
3. Login to apps using: apis.{app}.login(username=email, password=password)
4. Call APIs and print results to see them
5. Handle pagination: keep calling with page=2, page=3, etc. until results are empty
6. Complete: apis.supervisor.complete_task() or apis.supervisor.complete_task(answer="...")

## Key APIs
- apis.supervisor.show_account_passwords() — returns dict of app passwords
- apis.supervisor.show_profile() — returns supervisor's profile info
- apis.api_docs.search_api_docs(query="...") — search for APIs by keyword
- apis.spotify.login(username=email, password=password) — returns access_token

## Venmo Tasks
When task mentions relationships (roommates, siblings, coworkers, friends):
1. Get contacts: apis.supervisor.show_contacts() — returns list with relationship field
2. Filter contacts by relationship type to get their user IDs
3. Login to Venmo: apis.venmo.login(username=email, password=password) — returns access_token
4. Get social feed: apis.venmo.show_social_feed(access_token=token) — returns transactions
5. Filter transactions by date and check if sender_id or receiver_id matches contact IDs
6. Like transaction: apis.venmo.add_transaction_like(access_token=token, transaction_id=id)

Respond with ONLY a Python code block. No explanation."""


def call_llm(messages: list[dict]) -> str:
    """Call Bedrock via subprocess to avoid freezegun time patching."""
    request = {
        "system": [{"text": SYSTEM_PROMPT}],
        "messages": [
            {"role": m["role"], "content": [{"text": m["content"]}]}
