```python
# Now build the CSV content with all 57 unique songs
csv_lines = ["Title,Artists"]

for song_id, song in all_songs.items():
    title = song['title']
    artists = song['artists']
    
    # Artists is a list of dicts with 'name' key
    if artists and isinstance(artists[0], dict):
        artist_names = [a['name'] for a in artists]
    else:
        artist_names = artists
    
    artists_str = "|".join(artist_names)
    
    # Use CSV quoting to handle commas in title/artists
    # Escape double quotes by doubling them
    title_escaped = title.replace('"', '""')
    artists_escaped = artists_str.replace('"', '""')
    
    # Quote fields that contain commas or quotes
    if ',' in title_escaped or '"' in title_escaped:
        title_escaped = f'"{title_escaped}"'
    if ',' in artists_escaped or '"' in artists_escaped:
        artists_escaped = f'"{artists_escaped}"'
    
    csv_lines.append(f"{title_escaped},{artists_escaped}")

csv_content = "\n".join(csv_lines)
print(f"CSV preview (first 10 rows):")
for line in csv_lines[:10]:
    print(line)
print(f"\nTotal rows (including header): {len(csv_lines)}")
```

