"""
AppWorld agent — the file auto-agent will modify to improve performance.

This is a minimal ReAct-style agent that uses an LLM to generate code
for AppWorld tasks. Auto-agent can modify the system prompt, add tools,
change the loop logic, etc.
"""

import os
import json
import subprocess
import sys
from appworld import AppWorld

MAX_STEPS = int(os.environ.get("MAX_STEPS", "10"))
PYTHON = sys.executable
LLM_SCRIPT = os.path.join(os.path.dirname(__file__), "llm_call.py")

# --- System Prompt ---
SYSTEM_PROMPT = """You are an autonomous agent that completes tasks by writing Python code.
You interact with AppWorld apps (Spotify, Amazon, Venmo, etc.) via API calls.

API call format: apis.{app_name}.{api_name}(**parameters)
Example: apis.spotify.login(email="user@example.com", password="pass123")

Important:
- Always log in to an app before calling authenticated APIs.
- Use apis.supervisor.show_profile() to get the supervisor's info.
- Use apis.supervisor.show_account_passwords() to get app passwords.
- Use apis.api_docs.search_apis(query="...") to find relevant APIs.
- When done, call apis.supervisor.complete_task() or apis.supervisor.complete_task(answer="...") for answer-seeking tasks.
- Print results so you can see them in the next step.

Respond with ONLY a Python code block. No explanation."""


def call_llm(messages: list[dict]) -> str:
    """Call Bedrock via subprocess to avoid freezegun time patching."""
    request = {
        "system": [{"text": SYSTEM_PROMPT}],
        "messages": [
            {"role": m["role"], "content": [{"text": m["content"]}]}
            for m in messages
        ],
        "inferenceConfig": {"maxTokens": 2048, "temperature": 0},
    }
    result = subprocess.run(
        [PYTHON, LLM_SCRIPT],
        input=json.dumps(request),
        capture_output=True,
        text=True,
        timeout=60,
    )
    if result.returncode != 0:
        raise RuntimeError(f"LLM call failed: {result.stderr}")
    return result.stdout.strip()


def extract_code(text: str) -> str:
    """Extract Python code from LLM response."""
    if "```python" in text:
        return text.split("```python")[1].split("```")[0].strip()
    if "```" in text:
        return text.split("```")[1].split("```")[0].strip()
    return text.strip()


def solve_task(world: AppWorld):
    """Run the agent loop to solve a single AppWorld task."""
    instruction = world.task.instruction
    supervisor = world.task.supervisor

    messages = [
        {
            "role": "user",
            "content": (
                f"Complete this task: {instruction}\n\n"
                f"Supervisor info:\n"
                f"  Name: {supervisor.first_name} {supervisor.last_name}\n"
                f"  Email: {supervisor.email}\n"
                f"  Phone: {supervisor.phone_number}\n\n"
                f"Write Python code to complete this task step by step."
            ),
        }
    ]

    for step in range(MAX_STEPS):
        response = call_llm(messages)
        code = extract_code(response)

        output = world.execute(code)

        if world.task_completed():
            break

        messages.append({"role": "assistant", "content": response})
        messages.append({
            "role": "user",
            "content": f"Execution output:\n{output}\n\nContinue with the next step. Write only Python code.",
        })
