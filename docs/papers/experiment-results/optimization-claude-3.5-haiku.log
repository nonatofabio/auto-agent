```python
# Login to Spotify
apis.spotify.login(email="joyce-weav@gmail.com", password=apis.supervisor.show_account_passwords()["spotify"])

# Get user's playlists
playlists = apis.spotify.get_user_playlists()

# Track to store most-liked song
most_liked_song = None
max_likes = 0

# Iterate through playlists
for playlist in playlists:
    # Get tracks in playlist
    tracks = apis.spotify.get_playlist_tracks(playlist_id=playlist['id'])
    
    # Check each track's likes
    for track in tracks:
        track_likes = apis.spotify.get_track_likes(track_id=track['id'])
        
        # Update most-liked song if needed
        if track_likes > max_likes:
            max_likes = track_likes
            most_liked_song = track['title']

# Print and report result
print(f"Most-liked song: {most_liked_song}")
apis.supervisor.complete_task(answer=most_liked_song)
```

